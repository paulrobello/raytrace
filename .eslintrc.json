{
  "root": true,
  "env": {
    "browser": true,
    "worker": true,
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "$": "readonly",
    "postMessage": "readonly",
    "self": "readonly"
  },
  "rules": {
    "no-dupe-keys": "error",
    "no-redeclare": "warn",
    "no-undef": "warn",
    "no-unused-vars": "warn",
    "no-fallthrough": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }]
  }
}
